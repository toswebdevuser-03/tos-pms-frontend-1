# TOS Tracker — web frontend (Vite) environment
#
# Base URL of the TOS Tracker backend (the server/ app, hosted separately).
# Leave empty until the backend is chosen/deployed — the app will still build
# and show the sign-in screen; data calls report "backend not configured".
#
# Examples:
#   VITE_API_BASE_URL=https://tos-tracker-api.onrender.com
#   VITE_API_BASE_URL=http://localhost:4000   (local server during dev)
#
# Set this in Vercel → Project → Settings → Environment Variables (then redeploy).
VITE_API_BASE_URL=
