{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/auth/:path*", "destination": "https://unread-staleness-cesspool.ngrok-free.dev/auth/:path*" },
    { "source": "/api/:path*", "destination": "https://unread-staleness-cesspool.ngrok-free.dev/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
